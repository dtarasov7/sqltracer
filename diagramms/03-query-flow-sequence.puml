@startuml
title Query Capture and Response Flow

actor Client
participant "PostgresProxyConnection" as Conn
participant "sqltracer_packetio" as PacketIO
participant "PostgreSQL" as Pg
participant "EventStore" as Store
participant "NPlusOneDetector" as N1
participant "TUI / Sinks" as Consumers

Client -> Conn : send Query / Parse+Bind+Execute
Conn -> PacketIO : read_protocol_message(client)
Conn -> Conn : _queue_pending_event(...)
Conn -> Pg : forward protocol message
Pg --> Conn : RowDescription / DataRow / CommandComplete
Conn -> PacketIO : read_protocol_message(upstream)
Conn -> Conn : collect response preview\n(size/row bounded)
Conn -> Store : add(pending, rows, status/error)
Store -> N1 : record(normalized_query, scope, args_signature)
Store --> Consumers : snapshot/wait_for_change
Conn --> Client : relay upstream response

@enduml
